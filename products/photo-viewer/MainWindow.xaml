<Window x:Class="PhotoViewerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetherOS Photo Viewer"
        Width="1100"
        Height="740"
        WindowStartupLocation="CenterScreen"
        Background="#0B1220"
        KeyDown="Window_KeyDown">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#111827" BorderBrush="#1F2937" BorderThickness="1" CornerRadius="12" Padding="12">
            <DockPanel LastChildFill="False">
                <Button Content="Open Images" Width="120" Height="34" Margin="0,0,10,0" Click="OpenImages_Click"/>
                <Button Content="Open Folder" Width="120" Height="34" Margin="0,0,14,0" Click="OpenFolder_Click"/>
                <Button Content="Prev" Width="80" Height="34" Margin="0,0,8,0" Click="Prev_Click"/>
                <Button Content="Next" Width="80" Height="34" Margin="0,0,14,0" Click="Next_Click"/>
                <Button Content="Fit" Width="70" Height="34" Margin="0,0,8,0" Click="Fit_Click"/>
                <Button Content="100%" Width="70" Height="34" Click="ResetZoom_Click"/>
                <TextBlock x:Name="ImageInfoText"
                           Margin="18,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#CBD5E1"
                           Text="No image loaded"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,14,0,14" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" ClipToBounds="True">
            <ScrollViewer x:Name="ImageScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Grid Background="#020617">
                    <Image x:Name="PreviewImage" Stretch="None" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <ScaleTransform x:Name="ImageScaleTransform" ScaleX="1" ScaleY="1"/>
                        </Image.RenderTransform>
                    </Image>
                </Grid>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="IndexText" Grid.Column="0" Foreground="#94A3B8" VerticalAlignment="Center" Text="0 / 0"/>
            <Slider x:Name="ZoomSlider"
                    Grid.Column="1"
                    Margin="12,0,12,0"
                    Minimum="0.1"
                    Maximum="5"
                    TickFrequency="0.1"
                    Value="1"
                    ValueChanged="ZoomSlider_ValueChanged"/>
            <TextBlock x:Name="ZoomText" Grid.Column="2" Foreground="#94A3B8" VerticalAlignment="Center" TextAlignment="Right" Text="Zoom: 100%"/>
        </Grid>
    </Grid>
</Window>
