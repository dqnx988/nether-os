<Window x:Class="Explorer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetherOS Explorer"
        Height="780"
        Width="1160"
        Icon="img/logo.png"
        Background="#F0F4F8"
        FontFamily="Segoe UI Variable, Segoe UI, system-ui"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F0F4F8"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SurfaceMutedBrush" Color="#F8FAFD"/>
        <SolidColorBrush x:Key="StrokeBrush" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6"/>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="24" ShadowDepth="0" Color="#0F172A" Opacity="0.06"/>
        <DropShadowEffect x:Key="HoverShadow" BlurRadius="32" ShadowDepth="0" Color="#3B82F6" Opacity="0.12"/>

        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#E2E8F0"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                <Border x:Name="PART_Indicator"
                                        Background="{TemplateBinding Foreground}"
                                        HorizontalAlignment="Left"
                                        CornerRadius="3"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SidebarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="8,3"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentPresenter Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#BFDBFE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DBEAFE"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DriveCardButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CardHost"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="16">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CardHost" Property="Background" Value="#F8FAFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CardHost" Property="Background" Value="#EFF5FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                SnapsToDevicePixels="true">
                            <GridViewRowPresenter Content="{TemplateBinding Content}"
                                                  Columns="{TemplateBinding GridView.ColumnCollection}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#E2E8F0"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#BFDBFE"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#DBEAFE"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#93C5FD"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#F1F5F9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#FFFFFF"
                                Padding="8"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="32"
                                                  Direction="270"
                                                  Opacity="0.12"
                                                  ShadowDepth="10"
                                                  Color="#0F172A"/>
                            </Border.Effect>
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  ContentSource="Header"
                                                  VerticalAlignment="Center"/>
                                <Path x:Name="Arrow"
                                      Grid.Column="1"
                                      Data="M0,0 L4,4 L0,8 Z"
                                      Fill="#64748B"
                                      Margin="8,0,0,0"
                                      VerticalAlignment="Center"
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <Popup x:Name="SubmenuPopup"
                               Placement="Right"
                               HorizontalOffset="-4"
                               IsOpen="{TemplateBinding IsSubmenuOpen}"
                               AllowsTransparency="True">
                            <Border Background="#FFFFFF"
                                    Padding="8"
                                    BorderBrush="#E2E8F0"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="32"
                                                      Direction="270"
                                                      Opacity="0.12"
                                                      ShadowDepth="10"
                                                      Color="#0F172A"/>
                                </Border.Effect>
                                <ItemsPresenter/>
                            </Border>
                        </Popup>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource StrokeBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="14,24,14,0">
                <TextBlock Text="NetherOS"
                           FontWeight="Bold"
                           FontSize="22"
                           Margin="18,0,0,28"
                           Foreground="{StaticResource PrimaryTextBrush}"/>

                <Button Style="{StaticResource SidebarButton}"
                        Click="NavigateToHome">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="img/home.png"
                               Width="20"
                               Height="20"
                               Margin="0,0,14,0"
                               VerticalAlignment="Center"/>
                        <TextBlock Text="Home"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   FontWeight="Medium"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="QUICK ACCESS"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="18,24,0,10"/>



                <Button Style="{StaticResource SidebarButton}"
                        Click="NavigateToDesktop">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="img/desktop.png"
                               Width="20"
                               Height="20"
                               Margin="0,0,14,0"
                               VerticalAlignment="Center"/>
                        <TextBlock Text="Desktop"
                                   FontSize="14"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SidebarButton}"
                        Click="NavigateToDownloads">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="img/downloads.png"
                               Width="20"
                               Height="20"
                               Margin="0,0,14,0"
                               VerticalAlignment="Center"/>
                        <TextBlock Text="Downloads"
                                   FontSize="14"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SidebarButton}"
                        Click="NavigateToDocuments">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="img/documents.png"
                               Width="20"
                               Height="20"
                               Margin="0,0,14,0"
                               VerticalAlignment="Center"/>
                        <TextBlock Text="Documents"
                                   FontSize="14"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SidebarButton}"
                        Click="NavigateToPictures">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="img/pictures.png"
                               Width="20"
                               Height="20"
                               Margin="0,0,14,0"
                               VerticalAlignment="Center"/>
                        <TextBlock Text="Pictures"
                                   FontSize="14"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SidebarButton}"
                        Click="NavigateToVideos">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="img/videos.png"
                               Width="20"
                               Height="20"
                               Margin="0,0,14,0"
                               VerticalAlignment="Center"/>
                        <TextBlock Text="Videos"
                                   FontSize="14"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SidebarButton}"
                        Click="NavigateToMusic">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="img/music.png"
                               Width="20"
                               Height="20"
                               Margin="0,0,14,0"
                               VerticalAlignment="Center"/>
                        <TextBlock Text="Music"
                                   FontSize="14"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1"
              Background="{StaticResource AppBackgroundBrush}">
            <Grid Margin="28">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TOP BAR -->
                <StackPanel Grid.Row="0">
                    <Border Background="{StaticResource SurfaceBrush}"
                            Padding="18,13"
                            Margin="0,0,0,10"
                            BorderBrush="{StaticResource StrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="24"
                                              Opacity="0.06"
                                              ShadowDepth="0"
                                              Color="#0F172A"/>
                        </Border.Effect>
                        <TextBox x:Name="PathBar"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"
                                 Foreground="#475569"
                                 FontSize="13"
                                 FontFamily="Consolas, Monospace"
                                 KeyDown="PathBar_KeyDown"/>
                    </Border>

                    <Button x:Name="GoUpButton"
                            Click="GoUp_Click"
                            HorizontalAlignment="Left"
                            Padding="16,11"
                            Margin="0,0,0,18"
                            Background="#FFFFFF"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="img/folder.png"
                                   Width="16"
                                   Height="16"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                            <TextBlock Text="Go up"
                                       FontSize="13"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Foreground="#1F2937"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- CONTENT -->
                <Grid Grid.Row="1">
                    <ScrollViewer x:Name="DrivesControl"
                                  Visibility="Visible"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Devices and Drives"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Margin="0,0,0,22"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>
                            <ItemsControl x:Name="DrivesList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource DriveCardButton}"
                                                Click="Drive_Click"
                                                Tag="{Binding FullPath}"
                                                Margin="0,0,20,20"
                                                Width="300"
                                                Background="Transparent"
                                                BorderThickness="0">
                                            <Border Background="{StaticResource SurfaceBrush}"
                                                    BorderBrush="{StaticResource StrokeBrush}"
                                                    BorderThickness="1"
                                                    Padding="20"
                                                    CornerRadius="16">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="24"
                                                                      Opacity="0.06"
                                                                      ShadowDepth="0"
                                                                      Color="#0F172A"/>
                                                </Border.Effect>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid Width="42"
                                                          Height="42"
                                                          Margin="0,0,18,0"
                                                          VerticalAlignment="Center">
                                                        <Image Source="{Binding IconSource}"
                                                               Stretch="Uniform"/>
                                                        <TextBlock Text="{Binding IconEmoji}"
                                                                   FontSize="38"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IconSource}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="15"
                                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                                        <TextBlock Text="{Binding Size}"
                                                                   FontSize="12"
                                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                                   Margin="0,4,0,10"/>
                                                        <ProgressBar Value="{Binding UsedPercentage}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <ListView x:Name="FileListView"
                              Visibility="Collapsed"
                              BorderThickness="0"
                              Background="{StaticResource SurfaceBrush}"
                              MouseDoubleClick="FileListView_MouseDoubleClick"
                              PreviewMouseRightButtonDown="FileListView_PreviewMouseRightButtonDown">
                        <ListView.ContextMenu>
                            <ContextMenu Opened="FileContextMenu_Opened">
                                <MenuItem x:Name="OpenMenuItem"
                                          Click="Open_Click"
                                          FontWeight="Bold">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="↗" Margin="0,0,10,0"/>
                                            <TextBlock Text="Open"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem x:Name="CutMenuItem" Click="Cut_Click">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="img/cut-item.png" Width="16" Height="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="Cut"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem x:Name="CopyMenuItem" Click="Copy_Click">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="img/copy-item.png" Width="16" Height="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="Copy"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem x:Name="PasteMenuItem" Click="Paste_Click">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="img/paste-item.png" Width="16" Height="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="Paste"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <Separator/>
                                <MenuItem x:Name="RenameMenuItem" Click="Rename_Click">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <Image Source="img/rename-icon.png" Width="16" Height="16" Margin="0,0,10,0"/>
                                            <TextBlock Text="Rename"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <Separator/>
                                <MenuItem x:Name="DeleteMenuItem" Click="Delete_Click" Foreground="#DC2626">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🗑" Margin="0,0,10,0"/>
                                            <TextBlock Text="Delete"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <Separator/>
                                <MenuItem x:Name="PropertiesMenuItem" Click="Properties_Click">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="ℹ" Margin="0,0,10,0"/>
                                            <TextBlock Text="Properties"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <Separator/>
                                <MenuItem FontWeight="SemiBold">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="＋" Margin="0,0,10,0"/>
                                            <TextBlock Text="New"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                    <MenuItem x:Name="NewFolderMenuItem" Click="NewFolder_Click">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📁" Margin="0,0,10,0"/>
                                                <TextBlock Text="Folder"/>
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem x:Name="NewTextFileMenuItem" Click="NewTextFile_Click">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📄" Margin="0,0,10,0"/>
                                                <TextBlock Text="Text file (.txt)"/>
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                                    <MenuItem x:Name="NewZipFileMenuItem" Click="NewZipFile_Click">
                                        <MenuItem.Header>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🗜" Margin="0,0,10,0"/>
                                                <TextBlock Text="Compressed folder (.zip)"/>
                                            </StackPanel>
                                        </MenuItem.Header>
                                    </MenuItem>
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Name" Width="450">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Grid Width="24" Height="24" Margin="5,0,12,0">
                                                    <Image Source="{Binding IconSource}" Stretch="Uniform">
                                                        <Image.Style>
                                                            <Style TargetType="Image">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Image.Style>
                                                    </Image>
                                                    <TextBlock Text="{Binding IconEmoji}" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="14" Foreground="{StaticResource PrimaryTextBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Size" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Size}" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" FontSize="13"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Type" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FileType}" Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center" FontSize="13"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
        </Grid>
</Window>
