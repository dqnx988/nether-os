<Window x:Class="MusicPlayerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetherOS Music Player"
        Width="900"
        Height="620"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        FontFamily="Segoe UI Variable, Segoe UI">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111827" CornerRadius="16" Padding="16" Margin="0,0,14,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Playlist" FontSize="24" FontWeight="SemiBold" Foreground="#F9FAFB" Margin="0,0,0,12"/>
                    <Button Content="Add Songs" Click="AddSongs_Click" Height="36" Margin="0,0,0,10"/>
                </StackPanel>
                <ListBox x:Name="PlaylistList"
                         SelectionChanged="PlaylistList_SelectionChanged"
                         Background="#1F2937"
                         Foreground="#E5E7EB"
                         BorderBrush="#374151"
                         BorderThickness="1"
                         Padding="6"/>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="#111827" CornerRadius="16" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Now Playing" FontSize="24" FontWeight="SemiBold" Foreground="#F9FAFB"/>
                <TextBlock x:Name="SongTitleText"
                           Grid.Row="1"
                           Margin="0,8,0,16"
                           Text="No song selected"
                           FontSize="16"
                           Foreground="#93C5FD"
                           TextTrimming="CharacterEllipsis"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,14">
                    <Button x:Name="PlayPauseButton" Content="Play" Width="110" Height="38" Click="PlayPauseButton_Click" Margin="0,0,10,0"/>
                    <Button Content="Stop" Width="110" Height="38" Click="StopButton_Click" Margin="0,0,10,0"/>
                    <TextBlock Text="Volume" VerticalAlignment="Center" Foreground="#D1D5DB" Margin="6,0,8,0"/>
                    <Slider x:Name="VolumeSlider" Width="180" Minimum="0" Maximum="1" Value="0.65" ValueChanged="VolumeSlider_ValueChanged"/>
                </StackPanel>

                <Border Grid.Row="3" Background="#0B1220" CornerRadius="12" BorderBrush="#1F2937" BorderThickness="1">
                    <Grid VerticalAlignment="Center">
                        <TextBlock x:Name="StatusText"
                                   Text="Drop songs in playlist and press Play."
                                   Foreground="#9CA3AF"
                                   FontSize="15"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="4" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="CurrentTimeText" Text="00:00" Foreground="#D1D5DB" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Slider x:Name="PositionSlider"
                            Grid.Column="1"
                            Minimum="0"
                            Maximum="100"
                            ValueChanged="PositionSlider_ValueChanged"
                            PreviewMouseLeftButtonUp="PositionSlider_PreviewMouseLeftButtonUp"/>
                    <TextBlock x:Name="TotalTimeText" Grid.Column="2" Text="00:00" Foreground="#D1D5DB" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </Grid>
            </Grid>
        </Border>

        <MediaElement x:Name="Player"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Manual"
                      MediaOpened="Player_MediaOpened"
                      MediaEnded="Player_MediaEnded"
                      MediaFailed="Player_MediaFailed"
                      Visibility="Collapsed"/>
    </Grid>
</Window>
