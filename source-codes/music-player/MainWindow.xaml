<Window x:Class="MusicPlayerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetherOS Music Player"
        Width="920"
        Height="640"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimaryBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, system-ui"
        AllowsTransparency="False"
        SnapsToDevicePixels="True">

    <Window.Effect>
        <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="#1E293B" Opacity="0.5"/>
    </Window.Effect>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Playlist Panel -->
        <Border Grid.Column="0"
                Background="{StaticResource BgSecondaryBrush}"
                CornerRadius="18"
                Padding="18"
                BorderBrush="{StaticResource BorderPrimaryBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#000000" Opacity="0.3"/>
            </Border.Effect>
            <DockPanel>
                <!-- Header -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                    <DockPanel VerticalAlignment="Center" Margin="0,0,0,0">
                        <TextBlock Text="Music" FontSize="22" FontWeight="Bold" Foreground="#60A5FA" Margin="0,0,8,0"/>
                        <TextBlock Text="Player" FontSize="22" FontWeight="SemiBold" Foreground="#94A3B8"/>
                    </DockPanel>
                </StackPanel>

                <!-- Add Songs Button -->
                <Button x:Name="AddSongsButton"
                        Content="+ Add Songs"
                        Click="AddSongs_Click"
                        Height="38"
                        DockPanel.Dock="Top"
                        Background="{StaticResource AccentGradient}"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        FontWeight="SemiBold"
                        Padding="18,8"
                        Margin="0,0,0,12">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#3B82F6" Opacity="0.4"/>
                    </Button.Effect>
                </Button>

                <!-- Song Count & Stats -->
                <Border DockPanel.Dock="Top"
                        Background="#1E293B"
                        CornerRadius="8"
                        Padding="12,8"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SongCountText"
                                   Text="0 songs"
                                   Foreground="#94A3B8"
                                   FontSize="12"/>
                        <TextBlock Grid.Column="1"
                                   Text="Drag &amp; drop supported"
                                   Foreground="#64748B"
                                   FontSize="11"/>
                    </Grid>
                </Border>

                <!-- Playlist -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource BgTertiaryBrush}"
                        CornerRadius="10"
                        BorderBrush="{StaticResource BorderPrimaryBrush}"
                        BorderThickness="1">
                    <ListBox x:Name="PlaylistList"
                             SelectionChanged="PlaylistList_SelectionChanged"
                             Background="Transparent"
                             Foreground="{StaticResource TextSecondaryBrush}"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Padding="6,6,2,6">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="2">
                                    <TextBlock Text="►" FontSize="12" Foreground="#3B82F6" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>
        </Border>

        <!-- Spacer Column -->
        <Rectangle Grid.Column="1" Fill="Transparent"/>

        <!-- Player Panel -->
        <Border Grid.Column="2"
                Background="{StaticResource BgSecondaryBrush}"
                CornerRadius="18"
                Padding="24"
                BorderBrush="{StaticResource BorderPrimaryBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#000000" Opacity="0.3"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="Now Playing" FontSize="18" FontWeight="SemiBold" Foreground="#94A3B8"/>
                </StackPanel>

                <!-- Song Title -->
                <Border Grid.Row="1"
                        Background="#0F172A"
                        CornerRadius="12"
                        Padding="18,16"
                        Margin="0,0,0,20">
                    <TextBlock x:Name="SongTitleText"
                               Text="No song selected"
                               FontSize="21"
                               FontWeight="SemiBold"
                               Foreground="#60A5FA"
                               TextTrimming="CharacterEllipsis"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Main Controls -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <!-- Play/Pause -->
                    <Button x:Name="PlayPauseButton"
                            Content="Play"
                            Width="110"
                            Height="48"
                            Click="PlayPauseButton_Click"
                            Margin="0,0,12,0"
                            Background="{StaticResource AccentGradient}"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontWeight="SemiBold"
                            FontSize="16"
                            ToolTip="Play">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="14"
                                        RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="scale" Property="ScaleX" Value="1.05"/>
                                        <Setter TargetName="scale" Property="ScaleY" Value="1.05"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="scale" Property="ScaleX" Value="0.95"/>
                                        <Setter TargetName="scale" Property="ScaleY" Value="0.95"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Stop -->
                    <Button x:Name="StopButton"
                            Content="Stop"
                            Width="110"
                            Height="48"
                            Click="StopButton_Click"
                            Margin="0,0,12,0"
                            Background="#1E293B"
                            Foreground="#94A3B8"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontWeight="SemiBold"
                            FontSize="16"
                            ToolTip="Stop">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="12"
                                        RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="scale" Property="ScaleX" Value="1.05"/>
                                        <Setter TargetName="scale" Property="ScaleY" Value="1.05"/>
                                        <Setter TargetName="border" Property="Background" Value="#334155"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="scale" Property="ScaleX" Value="0.95"/>
                                        <Setter TargetName="scale" Property="ScaleY" Value="0.95"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Volume Control -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                        <TextBlock Text="Vol:" FontSize="13" FontWeight="SemiBold" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Slider x:Name="VolumeSlider"
                                Width="140"
                                Minimum="0"
                                Maximum="1"
                                Value="0.65"
                                ValueChanged="VolumeSlider_ValueChanged"
                                Height="4"
                                VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Visualization / Status Area -->
                <Border Grid.Row="3"
                        Background="Transparent"
                        CornerRadius="14"
                        BorderBrush="#334155"
                        BorderThickness="1"
                        Margin="0,0,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Visualizer placeholder -->
                        <Canvas x:Name="VisualizerCanvas"
                                Grid.Row="0"
                                Margin="8"
                                Background="#0F172A"
                                CornerRadius="10"/>

                        <!-- Status text -->
                        <Border Grid.Row="1" Background="Transparent" Padding="12,8,12,12">
                            <TextBlock x:Name="StatusText"
                                       Text="Drop songs in playlist and press Play."
                                       Foreground="#64748B"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       FontStyle="Italic"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Timeline & Time -->
                <Grid Grid.Row="4" Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Progress Slider -->
                    <Slider x:Name="PositionSlider"
                            Grid.Row="0"
                            Minimum="0"
                            Maximum="100"
                            ValueChanged="PositionSlider_ValueChanged"
                            PreviewMouseLeftButtonUp="PositionSlider_PreviewMouseLeftButtonUp"
                            Height="6"
                            Margin="0,0,0,8"
                            VerticalAlignment="Center"/>

                    <!-- Time Labels -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock x:Name="CurrentTimeText"
                                   Text="0:00"
                                   Foreground="#94A3B8"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="2"
                                   x:Name="TotalTimeText"
                                   Text="0:00"
                                   Foreground="#94A3B8"
                                   FontSize="13"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Grid>

            </Grid>
        </Border>

        <!-- Hidden MediaElement -->
        <MediaElement x:Name="Player"
                      LoadedBehavior="Manual"
                      UnloadedBehavior="Manual"
                      MediaOpened="Player_MediaOpened"
                      MediaEnded="Player_MediaEnded"
                      MediaFailed="Player_MediaFailed"
                      Visibility="Collapsed"/>

    </Grid>
</Window>
