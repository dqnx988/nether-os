<Window x:Class="ui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nether OS Taskbar"
        Height="45"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        Left="0"
        Top="1"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Grid>
        <Border Background="#1E1E1E" BorderBrush="#3F3F3F" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <ColumnDefinition Width="*"/>    <ColumnDefinition Width="Auto"/> </Grid.ColumnDefinitions>

                <Button x:Name="MenuButton"
                        Grid.Column="0"
                        Width="38"
                        Height="38"
                        Margin="5,2"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="MenuButton_Click">
                    <Image x:Name="MenuLogo"
                           Source="pack://application:,,,/img/logo-small.png"
                           Width="26"
                           Height="26"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           ImageFailed="MenuLogo_ImageFailed"/>
                </Button>

                <ListBox x:Name="OpenWindowsList"
                         Grid.Column="1"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalAlignment="Center"
                         MaxHeight="38"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2A2A2A"
                                    CornerRadius="4"
                                    Width="32"
                                    Height="32"
                                    Padding="5"
                                    Margin="2,0"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="OpenWindowItem_Click">
                                <Image Source="{Binding Icon}" 
                                       RenderOptions.BitmapScalingMode="HighQuality"
                                       ToolTip="{Binding Title}"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border x:Name="DateTimeBorder"
                        Grid.Column="2"
                        Background="#2A2A2A"
                        CornerRadius="3"
                        Padding="8,3"
                        Margin="10,0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Cursor="Hand"
                        MouseLeftButtonUp="DateTimeBorder_MouseLeftButtonUp">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ClockText" Text="00:00" Foreground="White" FontSize="14" FontFamily="Consolas"/>
                        <TextBlock x:Name="DateText" Text="01/01" Foreground="#888888" FontSize="12" FontFamily="Consolas" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Popup x:Name="MenuPopup" PlacementTarget="{Binding ElementName=MenuButton}" Placement="Top" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="#2D2D2D" BorderBrush="#3F3F3F" BorderThickness="1" CornerRadius="8" Padding="15">
                        <StackPanel Width="240">
                            <TextBlock Text="Nether OS" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Separator Background="#444444" Margin="0,5"/>
                            
                            <TextBlock Text="NOW PLAYING" Foreground="#555555" FontSize="10" FontWeight="Bold" Margin="0,10,0,5"/>
                            <TextBlock x:Name="MenuNowPlayingText" Text="No music playing" Foreground="#00FFCC" FontSize="13" TextWrapping="Wrap"/>
                            
                            <Separator Background="#444444" Margin="0,15,0,10"/>
                            <Button Content="Shutdown" Background="#3F3F3F" Foreground="White" BorderThickness="0" Padding="5"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <Popup x:Name="DateTimePopup" PlacementTarget="{Binding ElementName=DateTimeBorder}" Placement="Top" StaysOpen="False" AllowsTransparency="True">
                    <Border Background="#2D2D2D" BorderBrush="#3F3F3F" BorderThickness="1" CornerRadius="8" Padding="15">
                        <StackPanel Width="220">
                            <TextBlock x:Name="PopupClockText" Text="00:00" Foreground="White" FontSize="32" HorizontalAlignment="Center" FontFamily="Consolas"/>
                            <TextBlock x:Name="PopupDateText" Text="Datum" Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Center"/>
                            <Separator Background="#444444" Margin="0,10"/>
                            <TextBlock x:Name="PopupDayOfYearText" Text="Den X z 365" Foreground="#777777" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>
        </Border>
    </Grid>
</Window>