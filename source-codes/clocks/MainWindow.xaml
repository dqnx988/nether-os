<Window x:Class="ClocksApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetherOS Clock"
        Height="520"
        Width="420"
        ResizeMode="CanResize"
        WindowState="Normal"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI, system-ui">

    <Window.Resources>
        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#2d2d2d"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.3" Color="Black"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#404040"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#00d4aa"/>
                                <Setter Property="Foreground" Value="#0f0f0f"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Button Style -->
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#aaaaaa"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Digital Text Style -->
        <Style x:Key="DigitalText" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="#00d4aa"/>
        </Style>

        <!-- Accent Button Style -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#00d4aa"/>
            <Setter Property="Foreground" Value="#0f0f0f"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Border Background="#1a1a1a"
            CornerRadius="20"
            Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="#000000" Opacity="0.6"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <DockPanel Grid.Row="0" Margin="4,0,4,16">
                <TextBlock Text="Clock"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="#94A3B8"
                           VerticalAlignment="Center"
                           Margin="20,0,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="−"
                            Style="{StaticResource ModernButton}"
                            Padding="8,4"
                            FontSize="14"
                            Click="Minimize_Click"/>
                    <Button Content="×"
                            Style="{StaticResource ModernButton}"
                            Padding="8,4"
                            FontSize="14"
                            Margin="4,0,0,0"
                            Click="Close_Click"/>
                </StackPanel>
            </DockPanel>

            <!-- Tabs -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,25">
                <Button Name="ClockTab" Content="Clock" Style="{StaticResource TabButton}" Click="ClockTab_Click"/>
                <Button Name="StopwatchTab" Content="Stopwatch" Style="{StaticResource TabButton}" Click="StopwatchTab_Click"/>
                <Button Name="TimerTab" Content="Timer" Style="{StaticResource TabButton}" Click="TimerTab_Click"/>
            </StackPanel>

            <!-- Content -->
            <Grid Grid.Row="2">
                <Grid Name="ClockPanel">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Padding="40,30">
                            <StackPanel>
                                <TextBox Name="ClockDisplay" Style="{StaticResource DigitalText}"
                                         FontSize="72" FontWeight="Light" TextAlignment="Center"
                                         Text="00:00:00"/>
                                <TextBox Name="DateDisplay" Style="{StaticResource DigitalText}"
                                         FontSize="16" TextAlignment="Center" Foreground="#555555" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
                <Grid Name="StopwatchPanel" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Padding="45,35">
                            <StackPanel>
                                <TextBox Name="StopwatchDisplay" Style="{StaticResource DigitalText}"
                                         FontSize="60" FontWeight="Light" TextAlignment="Center"
                                         Text="00:00.00"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                                    <Button Name="StopwatchStartBtn" Content="Start" Style="{StaticResource AccentButton}" Click="StopwatchStart_Click" Margin="6"/>
                                    <Button Name="StopwatchStopBtn" Content="Stop" Style="{StaticResource ModernButton}" Click="StopwatchStop_Click" Margin="6" IsEnabled="False"/>
                                    <Button Name="StopwatchResetBtn" Content="Reset" Style="{StaticResource ModernButton}" Click="StopwatchReset_Click" Margin="6"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
                <Grid Name="TimerPanel" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Padding="45,35">
                            <StackPanel>
                                <TextBox Name="TimerDisplay" Style="{StaticResource DigitalText}"
                                         FontSize="60" FontWeight="Light" TextAlignment="Center"
                                         Text="00:00"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                                    <Border CornerRadius="6" Padding="12,6" Background="#2d2d2d">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox Name="TimerInput" Style="{StaticResource DigitalText}"
                                                     FontSize="18" Width="70" TextAlignment="Center"
                                                     Background="Transparent" Padding="5,3"/>
                                            <TextBlock Text="min" Foreground="#555555" VerticalAlignment="Center" Margin="8,0,12,0" FontSize="13" FontFamily="Segoe UI"/>
                                            <Button Name="TimerSetBtn" Content="Set" Style="{StaticResource ModernButton}" Click="TimerSet_Click" Padding="12,6" FontSize="13"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                                    <Button Name="TimerStartBtn" Content="Start" Style="{StaticResource AccentButton}" Click="TimerStart_Click" Margin="6"/>
                                    <Button Name="TimerStopBtn" Content="Stop" Style="{StaticResource ModernButton}" Click="TimerStop_Click" Margin="6" IsEnabled="False"/>
                                    <Button Name="TimerResetBtn" Content="Reset" Style="{StaticResource ModernButton}" Click="TimerReset_Click" Margin="6"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>

