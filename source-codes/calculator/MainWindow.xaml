<Window x:Class="CalculatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NetherOS Calculator" Height="520" Width="360" ResizeMode="CanResize" WindowState="Normal" 
        WindowStyle="SingleBorderWindow"
        Background="#1a1a1a" WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/img/logo.png"
        PreviewKeyDown="Window_PreviewKeyDown"
        Focusable="True"
        Loaded="Window_Loaded">
    <Window.Resources>
        <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#5a5a5c" Offset="0"/>
            <GradientStop Color="#3a3a3c" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="CalculatorButton" TargetType="Button">
            <Setter Property="Background" Value="#3a3a3c"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MainBorder" 
                                CornerRadius="20" 
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MainBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.95" ScaleY="0.95"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="{StaticResource AppBackground}" CornerRadius="24" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#252525" CornerRadius="16" Margin="8" Padding="16 12">
                <TextBox Name="Display" 
                        FontSize="38" 
                        TextAlignment="Right" 
                        VerticalContentAlignment="Center"
                        IsReadOnly="True" 
                        Text="0" 
                        Background="Transparent" 
                        Foreground="White" 
                        BorderThickness="0"
                        CaretBrush="Transparent"
                        SelectionBrush="Transparent"/>
            </Border>

            <Grid Grid.Row="1" Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition/> <RowDefinition/> <RowDefinition/> <RowDefinition/> <RowDefinition/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/> <ColumnDefinition/> <ColumnDefinition/> <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Button Grid.Row="0" Grid.ColumnSpan="3" Content="AC" Click="Clear_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>
                <Button Grid.Row="0" Grid.Column="3" Content="÷" Click="Operator_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>

                <Button Grid.Row="1" Grid.Column="0" Content="7" Click="Number_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>
                <Button Grid.Row="1" Grid.Column="1" Content="8" Click="Number_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>
                <Button Grid.Row="1" Grid.Column="2" Content="9" Click="Number_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>
                <Button Grid.Row="1" Grid.Column="3" Content="×" Click="Operator_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>

                <Button Grid.Row="2" Grid.Column="0" Content="4" Click="Number_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>
                <Button Grid.Row="2" Grid.Column="1" Content="5" Click="Number_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>
                <Button Grid.Row="2" Grid.Column="2" Content="6" Click="Number_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>
                <Button Grid.Row="2" Grid.Column="3" Content="−" Click="Operator_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>

                <Button Grid.Row="3" Grid.Column="0" Content="1" Click="Number_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>
                <Button Grid.Row="3" Grid.Column="1" Content="2" Click="Number_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>
                <Button Grid.Row="3" Grid.Column="2" Content="3" Click="Number_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>
                <Button Grid.Row="3" Grid.Column="3" Content="+" Click="Operator_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>

                <Button Grid.Row="4" Grid.ColumnSpan="2" Content="0" Click="Number_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>
                <Button Grid.Row="4" Grid.Column="2" Content="," Click="Decimal_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>
                <Button Grid.Row="4" Grid.Column="3" Content="=" Click="Result_Click" 
                        Style="{StaticResource CalculatorButton}" Margin="6"/>
            </Grid>
        </Grid>
    </Border>
</Window>